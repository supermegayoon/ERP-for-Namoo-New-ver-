function loadData(){
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || initialData; }
  catch { return initialData; }
}
function saveData(data){ localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }
function n(v){ const x=Number(v); return Number.isFinite(x)?x:0; }
function usd(v){ return `$${n(v).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}`; }
function krw(v){ return `₩${Math.round(n(v)).toLocaleString()}`; }
function uid(prefix){ return `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}`; }

